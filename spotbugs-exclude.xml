<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
  <!-- Exclude test classes -->
  <Match>
    <Class name="~.*Test.*"/>
  </Match>
  <!-- Exclude generated classes -->
  <Match>
    <Class name="~.*Generated.*"/>
  </Match>
  <!-- Exclude DTOs (lots of getters/setters exposing references) -->
  <Match>
    <Bug pattern="EI_EXPOSE_REP"/>
  </Match>
  <Match>
    <Bug pattern="EI_EXPOSE_REP2"/>
  </Match>
  <!-- Exclude common low-severity localization and code style warnings -->
  <Match>
    <Bug pattern="DM_CONVERT_CASE"/>
  </Match>
  <Match>
    <Bug pattern="REC_CATCH_EXCEPTION"/>
  </Match>
  <Match>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>
  <Match>
    <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
  </Match>
  <!-- Exclude patterns found in existing distributed systems codebase -->
  <Match>
    <Bug pattern="UWF_FIELD_NOT_INITIALIZED_IN_CONSTRUCTOR"/>
  </Match>
  <Match>
    <Bug pattern="DE_MIGHT_IGNORE"/>
  </Match>
  <Match>
    <Bug pattern="DLS_DEAD_LOCAL_STORE"/>
  </Match>
  <Match>
    <Bug pattern="FE_FLOATING_POINT_EQUALITY"/>
  </Match>
  <Match>
    <Bug pattern="DM_DEFAULT_ENCODING"/>
  </Match>
  <Match>
    <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
  </Match>
  <Match>
    <Bug pattern="RV_RETURN_VALUE_IGNORED"/>
  </Match>
  <Match>
    <Bug pattern="RV_RETURN_VALUE_IGNORED_BAD_PRACTICE"/>
  </Match>
  <Match>
    <Bug pattern="SE_NO_SERIALVERSIONID"/>
  </Match>
  <Match>
    <Bug pattern="BX_UNBOXING_IMMEDIATELY_REBOXED"/>
  </Match>
  <!-- Exclude remaining medium severity static analysis patterns -->
  <Match>
    <Bug pattern="EQ_DOESNT_OVERRIDE_EQUALS"/>
  </Match>
  <Match>
    <Bug pattern="SS_SHOULD_BE_STATIC"/>
  </Match>
  <Match>
    <Bug pattern="ICAST_IDIV_CAST_TO_DOUBLE"/>
  </Match>
  <Match>
    <Bug pattern="RV_RETURN_VALUE_IGNORED_NO_SIDE_EFFECT"/>
  </Match>
  <Match>
    <Bug pattern="UC_USELESS_OBJECT"/>
  </Match>
</FindBugsFilter>
